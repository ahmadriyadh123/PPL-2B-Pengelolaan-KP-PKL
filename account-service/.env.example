# ==========================================================
# account-service environment template
# ----------------------------------------------------------
# Copy file ini ke `.env` dan isi sesuai environment lokal:
#   cp .env.example .env
#
# JANGAN commit file `.env` (sudah masuk .gitignore).
# Generate JWT_SECRET acak sebelum dipakai:
#   Linux/Mac    : openssl rand -base64 64
#   PowerShell   : [Convert]::ToBase64String((1..64 | ForEach-Object {Get-Random -Min 0 -Max 255}))
# ==========================================================

# --- JSON Web Token ---
# Wajib diisi. Minimal 64 karakter (hasil base64 dari 64 byte acak).
JWT_SECRET=
# Access token: 15 menit (900_000 ms)
JWT_ACCESS_EXP_MS=900000
# Refresh token: 7 hari (604_800_000 ms)
JWT_REFRESH_EXP_MS=604800000

# --- Database ---
DB_HOST=mysql
DB_PORT=3306
DB_NAME=db-account
DB_USERNAME=root
DB_PASSWORD=root

# --- Scheduled Job (deleteParticipantAccountJob) ---
# Kredensial committee tiap prodi yang dipakai job tahunan untuk hapus akun
# participant lama. Kalau kosong, job di-skip dengan log error (bukan crash).
SCHEDULED_JOB_D3_USERNAME=
SCHEDULED_JOB_D3_PASSWORD=
SCHEDULED_JOB_D4_USERNAME=
SCHEDULED_JOB_D4_PASSWORD=
